# === GESTION PERSONNEL - Configuration de Sécurité ===
# Copiez ce fichier en .env et modifiez les valeurs

# Clé secrète Flask (GÉNÉREZ UNE NOUVELLE !)
# Utilisez: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-very-long-random-string-32-bytes-minimum

# Base de données PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gestion_personnel

# Mail (optionnel)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=gestion.personnel@entreprise.fr
ADMIN_EMAIL=admin@entreprise.fr

# Mode
FLASK_ENV=development
FLASK_DEBUG=true

# Sécurité avancée (production)
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
